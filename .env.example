# Anthropic API (used for news relevance filtering in enrichment pipeline)
ANTHROPIC_API_KEY=

FIRECRAWL_API_KEY=fc-your-key-here
GITHUB_TOKEN=github_pat_your-token-here
PRODUCTHUNT_TOKEN=
TRUSTMRR_TOKEN=

# Neon Postgres (pooled — for app and Python sidecar)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Neon Postgres (direct — for Prisma migrations only)
DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Manual agent lane
MANUAL_AGENT_LABEL=Codex
MANUAL_RESEARCH_COMMAND=/research
MANUAL_PROSPECT_COMMAND=/prospect pipeline

# OpenRouter research worker
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3-flash-preview
OPENROUTER_WEB_ENGINE=
OPENROUTER_WEB_MAX_RESULTS=5
OPENROUTER_WEB_SEARCH_CONTEXT_SIZE=high
OPENROUTER_MAX_COMPLETION_TOKENS=3000
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=
